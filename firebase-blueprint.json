{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user authentication and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "student"] },
        "department": { "type": "string" },
        "academic_id": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Archived exam metadata.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Final", "Monthly", "Quiz"] },
        "subject_name": { "type": "string" },
        "code": { "type": "string" },
        "year": { "type": "string" },
        "semester": { "type": "string", "enum": ["Semester 1", "Semester 2", "Summer"] },
        "pdf_url": { "type": "string", "format": "uri" },
        "department": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] }
      },
      "required": ["type", "subject_name", "code", "year", "semester", "pdf_url", "department"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student grade record.",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "academic_id": { "type": "string" },
        "student_name": { "type": "string" },
        "test_id": { "type": "string" },
        "subject_name": { "type": "string" },
        "score": { "type": "number" },
        "grade_label": { "type": "string" },
        "status": { "type": "string", "enum": ["Pass", "Fail"] },
        "department": { "type": "string" },
        "year": { "type": "string" },
        "semester": { "type": "string" }
      },
      "required": ["student_id", "test_id", "score", "grade_label", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Archived exams."
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Student grades."
    }
  }
}
